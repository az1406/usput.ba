<% content_for :title, t("explore_bosnia.title") %>

<%# Navigation %>
<%= render "new_design/header" %>

<%# Spacer for fixed header %>
<div class="h-20"></div>

<div class="max-w-2xl mx-auto px-4 py-8" data-controller="explore-geo">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-base/7 font-semibold text-blue-600 dark:text-yellow-400"><%= t("explore_bosnia.eyebrow") %></h2>
    <p class="mt-2 text-3xl font-semibold tracking-tight text-balance text-gray-900 sm:text-4xl dark:text-white"><%= t("explore_bosnia.title") %></p>
    <p class="mt-3 text-sm text-gray-500 dark:text-gray-400"><%= t("explore_bosnia.subtitle") %></p>
  </div>

  <% if @experience_types.any? %>
    <div class="mt-10 grid grid-cols-2 gap-4 sm:gap-6">
      <% @experience_types.each do |type| %>
        <%= link_to explore_bosnia_experience_path(type.key),
              data: { explore_geo_target: "tile" },
              class: "group relative flex aspect-square flex-col items-center justify-center rounded-2xl border border-gray-200 bg-white p-4 text-center shadow-sm transition hover:shadow-lg hover:border-blue-300 dark:border-gray-700 dark:bg-gray-800 dark:hover:border-yellow-400/50" do %>
          <span class="text-base font-semibold text-gray-900 dark:text-white"><%= type.translate(:name, I18n.locale) %></span>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="mt-10 rounded-2xl border border-dashed border-gray-300 dark:border-gray-600 px-4 py-8 text-center text-sm text-gray-500 dark:text-gray-400">
      <%= t("explore_bosnia.empty_grid") %>
    </p>
  <% end %>
</div>
