<%# Private photo moments for each location on the plan. The passport that %>
<%# prints them lives on the profile page, next to the boarding pass. %>
<%# Locals: plan (a Plan record), moments_by_location_id (Hash of location_id => [Moment]). %>
<div class="bg-white dark:bg-gray-800 rounded-2xl p-4 sm:p-6 shadow-lg"
     data-controller="moments-panel"
     data-moments-panel-closed-label-value="<%= t('plans.moments.add_for_plan') %>"
     data-moments-panel-open-label-value="<%= t('plans.moments.hide_for_plan') %>">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white flex items-center">
        <svg class="w-5 h-5 mr-2 text-emerald-600 dark:text-emerald-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        <%= t("plans.moments.title") %>
      </h2>
      <div class="mt-1 ml-7">
        <%= render "plans/moments_summary", plan: plan, count: moments_by_location_id.values.sum(&:size) %>
      </div>
    </div>

    <button type="button"
            data-action="moments-panel#toggle"
            data-moments-panel-target="button"
            aria-expanded="false"
            aria-controls="plan-moments-panel"
            class="btn-primary inline-flex items-center px-4 py-2 rounded-lg text-sm font-semibold whitespace-nowrap flex-shrink-0">
      <svg class="w-4 h-4 mr-2 transition-transform" data-moments-panel-target="chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
      </svg>
      <span data-moments-panel-target="label"><%= t("plans.moments.add_for_plan") %></span>
    </button>
  </div>

  <div id="plan-moments-panel" data-moments-panel-target="panel" class="hidden mt-6">
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-4"><%= t("plans.moments.privacy_note") %></p>

    <div id="moment-flash"></div>

    <div class="space-y-4">
      <% plan.all_locations.each do |location| %>
        <%= render "plans/moment_location",
              plan: plan,
              location: location,
              moments: moments_by_location_id[location.id] || [] %>
      <% end %>
    </div>
  </div>
</div>
