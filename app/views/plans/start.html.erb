<% content_for :title, t("plans.start.title", plan: @plan.title) %>

<% content_for :head do %>
  <%= stylesheet_link_tag "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css", "data-turbo-track": "reload" %>
<% end %>

<%# Navigation %>
<%= render "new_design/header" %>

<%# Spacer for fixed header %>
<div class="h-20"></div>

<div class="max-w-2xl mx-auto px-4 py-8 overflow-x-hidden" data-controller="moment-lightbox">
  <div class="mb-6">
    <%= link_to plan_path(@plan),
          class: "inline-flex items-center gap-1 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
      <%= t("plans.start.back") %>
    <% end %>

    <h1 class="mt-3 text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white"><%= @plan.title %></h1>
    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400"><%= t("plans.start.subtitle") %></p>
  </div>

  <% if @locations.any? %>
    <div id="moment-flash"></div>

    <div class="space-y-4" data-controller="plan-deck">
      <% @locations.each do |location| %>
        <%= render "plans/walk_card",
              plan: @plan,
              location: location,
              moments: @moments_by_location_id[location.id] || [],
              visited: @visited_location_ids.include?(location.id),
              public_moments: @public_moments_by_location_id[location.id] || [],
              reviews: @reviews_by_location_id[location.id] || [],
              context: "walk" %>
      <% end %>

      <div class="hidden rounded-2xl border border-dashed border-gray-300 dark:border-gray-600 px-4 py-8 text-center"
           data-plan-deck-target="done">
        <p class="text-sm font-medium text-gray-700 dark:text-gray-200"><%= t("plans.start.deck_done", default: "Obišli ste sve. Bravo!") %></p>
      </div>
    </div>
  <% else %>
    <p class="rounded-2xl border border-dashed border-gray-300 dark:border-gray-600 px-4 py-8 text-center text-sm text-gray-500 dark:text-gray-400">
      <%= t("plans.start.empty") %>
    </p>
  <% end %>

  <div data-moment-lightbox-target="overlay"
       data-action="click->moment-lightbox#closeOnBackground"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/80 p-4">
    <button type="button" data-action="moment-lightbox#close"
            class="absolute top-4 right-4 flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/20"
            aria-label="<%= t('common.close', default: 'Zatvori') %>">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
    <img data-moment-lightbox-target="image" src="" alt="" class="max-h-[85vh] max-w-full rounded-lg object-contain shadow-2xl">
  </div>
</div>
