<%# One location's moments: existing photos, plus a drop zone to add another. %>
<%# Locals: plan (Plan), location (Location), moments (Array of Moment). %>
<div id="<%= dom_id(location, :moments) %>" class="border border-gray-200 dark:border-gray-700 rounded-xl p-4">
  <div class="flex items-start justify-between gap-3 mb-3">
    <div class="min-w-0">
      <h3 class="font-semibold text-gray-900 dark:text-white truncate"><%= location.name %></h3>
      <p class="text-xs text-gray-500 dark:text-gray-400">
        <%= location_type_label(location.category_key) %><%= " · #{location.city}" if location.city.present? %>
      </p>
    </div>
    <% if moments.any? %>
      <span class="inline-flex items-center rounded-full bg-emerald-100 dark:bg-emerald-900/30 px-2.5 py-0.5 text-xs font-medium text-emerald-800 dark:text-emerald-300 flex-shrink-0">
        <%= t("plans.moments.count", count: moments.size) %>
      </span>
    <% end %>
  </div>

  <% if moments.any? %>
    <div class="flex flex-wrap gap-3 mb-4">
      <% moments.each do |moment| %>
        <div class="relative">
          <%# Served by MomentsController#photo, not Active Storage — the blob %>
          <%# url is a bearer token and these photos are private. %>
          <% if moment.displayable? %>
            <button type="button" class="block cursor-zoom-in"
                    data-action="moment-lightbox#open"
                    data-moment-lightbox-url="<%= photo_plan_moment_path(plan, moment, size: "square") %>">
              <%= image_tag photo_plan_moment_path(plan, moment, size: "thumb"),
                    class: "w-24 h-24 object-cover rounded-lg border border-gray-200 dark:border-gray-700",
                    alt: moment.note.presence || location.name %>
            </button>
          <% end %>
          <%= button_to plan_moment_path(plan, moment),
                method: :delete,
                form: { data: { turbo_confirm: t("plans.moments.confirm_delete") } },
                class: "absolute -top-2 -right-2 w-6 h-6 rounded-full bg-red-600 text-white text-xs leading-none flex items-center justify-center shadow hover:bg-red-700",
                aria: { label: t("plans.moments.delete") } do %>
            ×
          <% end %>
          <% if moment.note.present? %>
            <p class="mt-1 w-24 text-xs text-gray-500 dark:text-gray-400 truncate" title="<%= moment.note %>"><%= moment.note %></p>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%= render "plans/moment_form", plan: plan, location: location %>
</div>
