<%# Locals: plan, location, moments, visited. Optional: alert, context.
    Moments live in the story carousel, not on the step; the check-in button is
    the desktop path (mobile checks in by swiping the card). %>
<% location_name = location.translate(:name, I18n.locale) %>
<% overlay = local_assigns.fetch(:overlay, false) %>
<% step_context = local_assigns.fetch(:context, nil) %>
<div id="<%= dom_id(location, :step) %>"
     class="<%= overlay ? "text-white" : "rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-4 shadow-sm" %>"
     data-walk-visited="<%= visited %>">
    <div class="flex items-start gap-4">
      <% unless overlay %>
        <span class="flex size-9 flex-shrink-0 items-center justify-center rounded-full <%= visited ? "bg-emerald-600" : "bg-emerald-100 dark:bg-emerald-900/30" %>">
          <svg class="size-5 <%= visited ? "text-white" : "text-emerald-600 dark:text-emerald-400" %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <% if visited %>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            <% else %>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <% end %>
          </svg>
        </span>
      <% end %>

      <% if local_assigns.fetch(:show_photo, true) && location.display_photos.any? %>
        <%= image_tag location.display_photos.first.variant(resize_to_fill: [ 64, 64 ]),
              class: "size-16 flex-shrink-0 rounded-lg object-cover",
              loading: "lazy", alt: location_name %>
      <% end %>

      <div class="min-w-0 flex-1">
        <div class="flex items-center gap-2">
          <% if local_assigns.fetch(:show_name, true) %>
            <h2 class="truncate font-semibold text-gray-900 dark:text-white"><%= location_name %></h2>
          <% end %>
          <% if visited %>
            <span class="inline-flex items-center rounded-full bg-emerald-600 px-2 py-0.5 text-xs font-medium text-white flex-shrink-0">
              <%= t("plans.start.visited") %>
            </span>
          <% end %>
        </div>
        <% if local_assigns.fetch(:show_name, true) %>
          <% meta = [ location.city, location_type_label(location.category_key) ].select(&:present?).join(" · ") %>
          <% if meta.present? %>
            <p class="mt-0.5 text-sm text-gray-500 dark:text-gray-400"><%= meta %></p>
          <% end %>
        <% end %>

      </div>
    </div>

    <% if local_assigns[:alert].present? %>
      <p class="mt-4 rounded-lg bg-red-50 dark:bg-red-900/30 px-3 py-2 text-sm text-red-800 dark:text-red-300">
        <%= alert %>
      </p>
    <% end %>

    <% if logged_in? %>
      <% if visited %>
      <% else %>
        <% check_class = overlay ? "mx-auto inline-flex items-center gap-1 rounded-full bg-emerald-600 px-5 py-2 text-sm font-semibold text-white shadow-lg cursor-pointer hover:bg-emerald-700" : "flex w-full items-center justify-center gap-2 rounded-xl border border-dashed border-gray-300 dark:border-gray-600 px-4 py-2.5 text-sm font-medium text-gray-600 dark:text-gray-300 cursor-pointer transition-colors hover:border-emerald-400 hover:bg-gray-50 dark:hover:bg-gray-700/40" %>
        <% if geofence_disabled? %>
          <%# Geofence off (dev/testing): a plain submit, no geolocation, no distance hint. %>
          <div class="<%= overlay ? "text-center" : "mt-4" %> hidden sm:block">
            <%= button_to plan_visits_path(plan), params: { location_id: location.uuid, user_lat: 0, user_lng: 0, context: step_context }.compact, class: check_class do %>
              <span><%= t("plans.start.mark_visited") %></span>
            <% end %>
          </div>
        <% else %>
          <div class="<%= overlay ? "text-center" : "mt-4" %> hidden sm:block"
               data-controller="geo-visit"
               data-geo-visit-lat-value="<%= location.lat %>"
               data-geo-visit-lng-value="<%= location.lng %>">
            <%= button_to plan_visits_path(plan),
                  params: { location_id: location.uuid, user_lat: "", user_lng: "", context: step_context }.compact,
                  class: check_class do %>
              <span><%= t("plans.start.mark_visited") %></span>
            <% end %>
            <p class="hidden mt-2 inline-block rounded-full bg-black/60 px-3 py-1 text-sm font-semibold text-white"
               data-geo-visit-target="hint"
               data-directions="<%= t('plans.start.compass', default: 'N,NE,E,SE,S,SW,W,NW') %>"></p>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <p class="mt-4 text-sm text-gray-500 dark:text-gray-400"><%= t("plans.start.login_to_capture") %></p>
    <% end %>
  </div>
