<%# Locals: plan, location, moments, visited, public_moments, reviews, context.
    Optional: distance_km. One card everywhere — explore scrolls it, the walk
    stacks it; context tags server round-trips with the owning surface. %>
<% reviews = local_assigns.fetch(:reviews, [])
   distance_km = local_assigns.fetch(:distance_km, nil)
   context = local_assigns.fetch(:context, nil)
   location_name = location.translate(:name, I18n.locale)
   description = strip_tags(location.translate(:description, I18n.locale).to_s).squish
   tour = location.has_audio_tours? ? location.audio_tour_with_fallback(I18n.locale) : nil %>

<div class="relative mx-auto aspect-[2/3] w-full max-h-full touch-pan-y overflow-hidden rounded-2xl bg-gray-900 shadow-sm sm:max-w-lg"
     data-controller="story-viewer card-menu"
     data-action="click->card-menu#open story-viewer:closed->card-menu#reveal"
     data-plan-deck-target="card"
     data-plan-deck-lat="<%= location.lat %>"
     data-plan-deck-lng="<%= location.lng %>"
     data-plan-deck-visited="<%= visited %>">
  <% if location.display_photos.any? %>
    <%= image_tag location.display_photos.first.variant(resize_to_fill: [ 720, 960 ]),
          class: "absolute inset-0 h-full w-full object-cover", loading: "lazy", alt: location_name %>
  <% else %>
    <div class="absolute inset-0 bg-gray-700"></div>
  <% end %>
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-black/50 via-transparent to-black/70"></div>

  <div class="absolute left-3 right-16 top-3 z-10">
    <h2 class="text-lg font-bold text-white drop-shadow"><%= location_name %></h2>
    <% if distance_km.present? %>
      <p class="text-xs font-medium text-white/80 drop-shadow"><%= t("explore_bosnia.km_away", km: number_with_precision(distance_km, precision: 1)) %></p>
    <% end %>
  </div>

  <div class="absolute right-3 top-3 z-20 flex flex-col items-end gap-2">
    <% if tour&.audio_file&.attached? %>
      <div data-controller="card-audio">
        <button type="button" data-action="card-audio#toggle"
                class="flex size-10 items-center justify-center rounded-full bg-white/90 text-emerald-600 shadow"
                aria-label="<%= t('plans.start.play_audio') %>">
          <svg data-card-audio-target="playIcon" class="size-5" fill="currentColor" viewBox="0 0 20 20"><path d="M6.3 2.8A1 1 0 004.8 3.7v12.6a1 1 0 001.5.9l10-6.3a1 1 0 000-1.7l-10-6.4z"/></svg>
          <svg data-card-audio-target="pauseIcon" class="hidden size-5" fill="currentColor" viewBox="0 0 20 20"><path d="M6 3h3v14H6zM11 3h3v14h-3z"/></svg>
        </button>
        <audio data-card-audio-target="player" preload="none" src="<%= rails_blob_path(tour.audio_file, only_path: true) %>"></audio>
      </div>
    <% end %>
  </div>

  <div class="absolute inset-x-0 bottom-4 z-10 px-4">
    <%= render "plans/plan_step", plan: plan, location: location, moments: moments, visited: visited,
          show_photo: false, show_name: false, overlay: true, context: context %>
  </div>

  <button type="button" data-card-menu-target="hint" data-action="card-menu#openFromHint"
            class="hidden absolute left-1/2 top-[36%] z-20 size-24 -translate-x-1/2 -translate-y-1/2 animate-pulse items-center justify-center rounded-full bg-sky-400/80 p-3 text-center text-xs font-semibold leading-snug text-white shadow-lg">
      <%= t("plans.start.tap_for_info") %>
    </button>

  <button type="button" data-plan-deck-target="storyHint"
            class="hidden absolute left-2 top-[62%] z-20 -translate-y-1/2 flex-col items-center gap-1.5">
      <span class="flex size-12 animate-pulse items-center justify-center rounded-full bg-sky-400/80 text-white shadow-lg">
        <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7M19 19l-7-7 7-7"/></svg>
      </span>
      <span class="max-w-28 text-center text-xs font-semibold leading-snug text-white drop-shadow"><%= t("plans.start.story_hint") %></span>
    </button>

  <%# Tap-anywhere menu: one overlay, four actions. %>
  <div class="hidden absolute inset-0 z-30 flex-col items-center justify-center gap-3 bg-black/70 px-8 backdrop-blur-sm"
       data-card-menu-target="menu">
    <button type="button" data-action="card-menu#close"
            class="absolute right-3 top-3 flex size-9 items-center justify-center rounded-full bg-white/15 text-white"
            aria-label="<%= t('common.close') %>">✕</button>
    <div class="grid w-full grid-cols-2 gap-3">
      <% if description.present? %>
        <button type="button" data-action="card-menu#show" data-panel="info"
                class="flex aspect-square flex-col items-center justify-center gap-2 rounded-2xl bg-white/95 p-3 text-sm font-semibold text-gray-900 shadow">
          <svg class="size-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <%= t("plans.start.info") %>
        </button>
      <% end %>
      <% if location.geocoded? %>
        <button type="button" data-action="card-menu#show" data-panel="map"
                class="flex aspect-square flex-col items-center justify-center gap-2 rounded-2xl bg-white/95 p-3 text-sm font-semibold text-gray-900 shadow">
          <svg class="size-7 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-1.447-.894L15 4m0 13V4m0 0L9 7"/></svg>
          <%= t("plans.start.map") %>
        </button>
      <% end %>
      <button type="button" data-action="card-menu#show" data-panel="reviews"
                class="flex aspect-square flex-col items-center justify-center gap-2 rounded-2xl bg-white/95 p-3 text-sm font-semibold text-gray-900 shadow">
          <svg class="size-7 text-amber-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <%= t("plans.start.reviews") %>
        </button>
      <button type="button" data-action="card-menu#moments"
              class="flex aspect-square flex-col items-center justify-center gap-2 rounded-2xl bg-white/95 p-3 text-sm font-semibold text-gray-900 shadow">
        <svg class="size-7 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <%= t("plans.start.shared_moments") %>
      </button>
    </div>
  </div>

  <p class="hidden absolute bottom-24 left-1/2 z-30 w-max max-w-[85%] -translate-x-1/2 rounded-full bg-black/70 px-4 py-2 text-center text-xs font-medium text-white" data-card-menu-target="locked"><%= t("plans.start.story_locked") %></p>
  <button type="button" class="hidden" data-story-open data-action="story-viewer#open" data-story-index="0" tabindex="-1" aria-hidden="true"></button>

  <% if description.present? %>
    <div class="hidden absolute inset-0 z-40 overflow-y-auto bg-gray-100 p-4 dark:bg-gray-800" data-card-menu-target="panel" data-panel="info">
      <div class="mb-3 flex items-center justify-between">
        <h3 class="text-base font-semibold text-gray-900 dark:text-white"><%= t("plans.start.info") %></h3>
        <button type="button" data-action="card-menu#back"
                class="flex size-9 items-center justify-center rounded-full bg-white text-gray-700 shadow dark:bg-gray-900/80 dark:text-gray-200"
                aria-label="<%= t('common.close') %>">✕</button>
      </div>
      <p class="text-sm leading-relaxed text-gray-700 dark:text-gray-200"><%= description %></p>
    </div>
  <% end %>

  <div class="hidden absolute inset-0 z-40 overflow-y-auto bg-gray-100 p-4 dark:bg-gray-800" data-card-menu-target="panel" data-panel="reviews">
      <div class="mb-3 flex items-center justify-between">
        <h3 class="text-base font-semibold text-gray-900 dark:text-white"><%= t("plans.start.reviews") %></h3>
        <button type="button" data-action="card-menu#back"
                class="flex size-9 items-center justify-center rounded-full bg-white text-gray-700 shadow dark:bg-gray-900/80 dark:text-gray-200"
                aria-label="<%= t('common.close') %>">✕</button>
      </div>
      <% if reviews.any? %>
        <div class="space-y-3">
          <%= render partial: "reviews/review_card", collection: reviews.first(5), as: :review %>
        </div>
      <% else %>
        <p class="rounded-xl border border-dashed border-gray-300 p-4 text-center text-sm text-gray-500 dark:border-gray-600 dark:text-gray-400"><%= t("plans.start.no_reviews") %></p>
      <% end %>
    </div>

  <button type="button" data-plan-deck-target="hint" data-action="plan-deck#dismissHint"
            class="hidden absolute right-2 top-[62%] z-20 -translate-y-1/2 flex-col items-center gap-1.5">
      <span class="flex size-12 animate-pulse items-center justify-center rounded-full bg-sky-400/80 text-white shadow-lg">
        <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"/></svg>
      </span>
      <span class="max-w-28 text-center text-xs font-semibold leading-snug text-white drop-shadow"><%= t("explore_bosnia.swipe_hint") %></span>
    </button>

  <%= render "plans/story_carousel", plan: plan, location: location,
        moments: moments, public_moments: public_moments, context: context %>

  <% if location.geocoded? %>
    <div class="hidden absolute inset-0 z-40 bg-gray-100 dark:bg-gray-700" data-card-menu-target="panel" data-panel="map">
      <div class="h-full w-full"
           data-controller="map"
           data-map-lat-value="<%= location.lat %>"
           data-map-lng-value="<%= location.lng %>"
           data-map-user-location-value="true"
           data-map-points-value="<%= [ { lat: location.lat.to_f, lng: location.lng.to_f, name: location_name, main: true } ].to_json %>">
        <div class="h-full w-full" data-map-target="container"></div>
      </div>
      <button type="button" data-action="card-menu#back"
              class="absolute right-3 top-3 z-[1000] flex size-9 items-center justify-center rounded-full bg-white/90 text-gray-700 shadow dark:bg-gray-900/80 dark:text-gray-200"
              aria-label="<%= t('common.close') %>">✕</button>
    </div>
  <% end %>
</div>
