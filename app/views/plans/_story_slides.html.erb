<%# Locals: plan, location, moments, public_moments, context.
    The inside of the story dialog — the piece moments/update morphs. %>
  <% own_stories = moments.to_a.select(&:displayable?).sort_by { |own| [ own.visibility_private_moment? ? 0 : 1, -own.created_at.to_i ] }
     other_stories = public_moments.select(&:displayable?).reject { |shared| logged_in? && shared.user_id == current_user.id }
     %>
    <div class="flex h-full w-full snap-x snap-mandatory overflow-x-auto overscroll-x-contain scroll-smooth pt-[env(safe-area-inset-top)] pb-[env(safe-area-inset-bottom)] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
         data-story-viewer-target="track">

      <% own_stories.each do |own| %>
        <div class="relative flex h-full w-full shrink-0 snap-center items-center justify-center px-0 sm:px-16" data-story-viewer-target="slide">
          <div class="relative aspect-[9/16] h-full max-w-full overflow-hidden rounded-none bg-gray-900 sm:h-[92%] sm:rounded-2xl">
            <img src="<%= photo_plan_moment_path(own.plan, own, size: "story") %>" alt="" class="absolute inset-0 h-full w-full object-cover">
            <span class="absolute left-3 top-6 sm:top-3 z-10 flex items-center gap-1.5 rounded-full bg-black/60 px-3 py-1 text-xs font-semibold <%= own.visibility_private_moment? ? "text-yellow-300" : (own.approved? ? "text-emerald-300" : "text-orange-300") %>">
              <% if own.visibility_private_moment? %>
                <svg class="size-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                <%= t("plans.start.story_private") %>
              <% elsif own.approved? %>
                <svg class="size-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0zM3.6 9h16.8M3.6 15h16.8M12 3a15 15 0 010 18M12 3a15 15 0 000 18"/></svg>
                <%= t("plans.start.story_public") %>
              <% else %>
                <svg class="size-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <%= t("plans.start.story_pending") %>
              <% end %>
            </span>
            <% if own.visibility_private_moment? %>
              <div data-controller="hint" data-hint-key-value="usput-publish-hint-seen"
                   data-action="click->hint#dismiss"
                   class="hidden absolute inset-x-6 bottom-[4.5rem] z-20 flex-col items-center gap-1 rounded-2xl bg-sky-400/90 px-4 py-2 text-center text-xs font-semibold text-white shadow-lg animate-pulse sm:bottom-14">
                <%= t("plans.start.publish_hint") %>
              </div>
            <% elsif own.visibility_public_moment? && !own.approved? %>
              <div data-controller="hint" data-hint-key-value="usput-pending-hint-seen"
                   data-action="click->hint#dismiss"
                   class="hidden absolute inset-x-3 top-16 z-20 flex-col items-start gap-1 rounded-2xl bg-sky-400/90 px-3 py-2 text-xs font-semibold text-white shadow-lg sm:top-12">
                <%= t("plans.start.pending_note") %>
              </div>
            <% end %>
            <div class="absolute inset-x-0 bottom-8 z-10 flex items-center justify-center gap-3 px-6 sm:bottom-4">
              <% if own.visibility_private_moment? %>
                <%= button_to t("plans.start.story_publish"), publish_plan_moment_path(own.plan, own),
                      method: :patch,
                      params: { context: context }.compact,
                      form: { data: { action: "submit->story-viewer#noteUpload" } },
                      class: "rounded-full bg-white/90 px-4 py-1.5 text-xs font-semibold text-gray-900 shadow" %>
              <% end %>
              <%= button_to t("plans.start.story_delete"), plan_moment_path(own.plan, own),
                    method: :delete,
                    params: { context: context }.compact,
                    form: { data: { turbo_confirm: t("plans.start.story_delete_confirm"), action: "submit->story-viewer#noteDelete" } },
                    class: "rounded-full bg-red-600/90 px-4 py-1.5 text-xs font-semibold text-white shadow" %>
            </div>
          </div>
        </div>
      <% end %>

      <% if other_stories.any? %>
        <% other_stories.first(6).each do |shared| %>
          <div class="relative flex h-full w-full shrink-0 snap-center items-center justify-center px-0 sm:px-16" data-story-viewer-target="slide">
            <div class="relative aspect-[9/16] h-full max-w-full overflow-hidden rounded-none bg-gray-900 sm:h-[92%] sm:rounded-2xl">
              <img src="<%= url_for(shared.photo.variant(resize_to_limit: [ 1080, 1080 ])) %>" alt="" class="absolute inset-0 h-full w-full object-cover">
              <span class="absolute left-3 top-6 sm:top-3 z-10 flex items-center gap-1.5 rounded-full bg-black/60 px-3 py-1 text-xs font-semibold text-emerald-300">
                <svg class="size-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0zM3.6 9h16.8M3.6 15h16.8M12 3a15 15 0 010 18M12 3a15 15 0 000 18"/></svg>
                <%= t("plans.start.story_public") %>
              </span>
            </div>
          </div>
        <% end %>
      <% end %>

      <% if own_stories.empty? && other_stories.empty? %>
        <div class="relative flex h-full w-full shrink-0 snap-center items-center justify-center px-0 sm:px-16" data-story-viewer-target="slide">
          <div class="flex aspect-[9/16] h-full max-w-full flex-col items-center justify-center gap-4 rounded-none bg-gray-900 p-6 sm:h-[92%] sm:rounded-2xl">
            <p class="text-center text-lg font-semibold text-white/90"><%= t("plans.start.story_none") %></p>
            <% if logged_in? %>
              <p class="text-center text-xs text-white/60"><%= t("plans.start.story_upload_note") %></p>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <button type="button" data-action="story-viewer#prev"
            class="absolute left-3 top-1/2 z-20 flex size-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/15 text-white hover:bg-white/25"
            aria-label="<%= t('common.previous') %>">
      <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <button type="button" data-action="story-viewer#next"
            class="absolute right-3 top-1/2 z-20 flex size-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/15 text-white hover:bg-white/25"
            aria-label="<%= t('common.next') %>">
      <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </button>

    <button type="button" class="absolute right-3 top-[calc(env(safe-area-inset-top)+0.75rem)] z-30 flex size-11 items-center justify-center rounded-full bg-white/20 text-white" data-action="story-viewer#close" aria-label="<%= t('common.close') %>">✕</button>

    <% if logged_in? %>
      <div class="pointer-events-none absolute inset-0 z-30 flex items-center justify-center px-0 pb-[env(safe-area-inset-bottom)] sm:px-16">
        <div class="relative aspect-[9/16] h-full max-w-full sm:h-[92%]">
          <button type="button" data-action="story-viewer#addMoment"
                  class="pointer-events-auto absolute bottom-4 right-3 flex size-14 items-center justify-center rounded-full bg-white text-gray-900 shadow-xl"
                  aria-label="<%= t('plans.start.story_add_private') %>">
            <svg class="size-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z"/></svg>
          </button>
          <div data-controller="hint" data-hint-key-value="usput-add-moment-hint-seen"
               data-action="click->hint#dismiss"
               class="pointer-events-auto hidden absolute bottom-20 right-3 max-w-56 flex-col items-end gap-1 rounded-2xl bg-sky-400/90 px-3 py-2 text-right text-xs font-semibold text-white shadow-lg animate-pulse">
            <%= t("plans.start.add_moment_note") %>
          </div>
        </div>
      </div>
    <% end %>
