<div class="space-y-4 sm:space-y-6">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <h1 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white"><%= t("curator.reviews.show_title") %></h1>
    <div class="flex flex-col sm:flex-row gap-2">
      <%# Not gated on :curator_edit_delete — removing a review is moderation, %>
      <%# not content editing, and has always been available to curators. %>
      <%= button_to curator_review_path(@review),
          method: :delete,
          class: "inline-flex items-center justify-center rounded-md bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500",
          data: { turbo_confirm: t("curator.reviews.confirm_delete") } do %>
        <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
        </svg>
        <%= t("curator.reviews.delete") %>
      <% end %>
      <%= link_to curator_reviews_path,
          class: "inline-flex items-center justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 dark:bg-gray-800 dark:text-white dark:ring-gray-600 dark:hover:bg-gray-700" do %>
        <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" />
        </svg>
        <%= t("curator.reviews.back_to_list") %>
      <% end %>
    </div>
  </div>

  <div class="rounded-lg bg-white dark:bg-gray-800 shadow">
    <div class="px-4 py-5 sm:px-6">
      <div class="flex items-center gap-2 mb-4">
        <div class="flex items-center">
          <% @review.rating.times do %>
            <svg class="h-5 w-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          <% end %>
          <% (5 - @review.rating).times do %>
            <svg class="h-5 w-5 text-gray-300 dark:text-gray-600" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          <% end %>
        </div>
        <span class="text-lg font-semibold text-gray-900 dark:text-white"><%= @review.rating %>/5</span>
      </div>

      <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2">
        <div>
          <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.reviews.author") %></dt>
          <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= @review.author_name.presence || @review.user&.username || t("reviews.anonymous") %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.reviews.type") %></dt>
          <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= @review.reviewable_type %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.reviews.item") %></dt>
          <dd class="mt-1 text-sm text-gray-900 dark:text-white">
            <% if @review.reviewable %>
              <%= @review.reviewable.try(:name) || @review.reviewable.try(:title) %>
            <% else %>
              <span class="text-red-500 dark:text-red-400"><%= t("curator.reviews.deleted_item") %></span>
            <% end %>
          </dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.reviews.created_at") %></dt>
          <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= @review.created_at.strftime("%d.%m.%Y %H:%M") %></dd>
        </div>
        <div class="sm:col-span-2">
          <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.reviews.comment") %></dt>
          <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= @review.comment.presence || t("curator.reviews.no_comment") %></dd>
        </div>
      </dl>

    </div>
  </div>
</div>
