<div class="space-y-4 sm:space-y-6">
  <%= render "curator/shared/pending_proposal_banner", pending_proposal: @pending_proposal %>

  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <h1 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white"><%= t("curator.audio_tours.show_title") %></h1>
    <div class="flex flex-col sm:flex-row gap-2">
      <% if Flipper.enabled?(:curator_edit_delete) %>
        <%= link_to edit_curator_audio_tour_path(@audio_tour),
            class: "inline-flex items-center justify-center rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-500" do %>
          <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
          </svg>
          <%= t("curator.audio_tours.edit") %>
        <% end %>
        <%= button_to curator_audio_tour_path(@audio_tour),
            method: :delete,
            class: "inline-flex items-center justify-center rounded-md bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500",
            data: { turbo_confirm: t("curator.audio_tours.confirm_delete") } do %>
          <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
          </svg>
          <%= t("curator.audio_tours.delete") %>
        <% end %>
      <% end %>
      <%= link_to curator_audio_tours_path,
          class: "inline-flex items-center justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 dark:bg-gray-800 dark:text-white dark:ring-gray-600 dark:hover:bg-gray-700" do %>
        <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" />
        </svg>
        <%= t("curator.audio_tours.back_to_list") %>
      <% end %>
    </div>
  </div>

  <div class="rounded-lg bg-white dark:bg-gray-800 shadow">
    <div class="px-4 py-5 sm:px-6">
      <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2">
        <div>
          <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.audio_tours.location") %></dt>
          <dd class="mt-1 text-sm text-gray-900 dark:text-white">
            <%= link_to @audio_tour.location.name, curator_location_path(@audio_tour.location), class: "text-emerald-600 dark:text-emerald-400 hover:text-emerald-900 dark:hover:text-emerald-300" %>
          </dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.audio_tours.locale") %></dt>
          <dd class="mt-1">
            <span class="inline-flex items-center rounded-full bg-blue-100 dark:bg-blue-900/40 px-2.5 py-0.5 text-xs font-medium text-blue-800 dark:text-blue-300">
              <%= @audio_tour.language_name %>
            </span>
          </dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.audio_tours.audio_status") %></dt>
          <dd class="mt-1">
            <% if @audio_tour.audio_ready? %>
              <span class="inline-flex items-center rounded-full bg-green-100 dark:bg-green-900/40 px-2.5 py-0.5 text-xs font-medium text-green-800 dark:text-green-300">
                <%= t("curator.audio_tours.ready") %>
              </span>
            <% else %>
              <span class="inline-flex items-center rounded-full bg-yellow-100 dark:bg-yellow-900/40 px-2.5 py-0.5 text-xs font-medium text-yellow-800 dark:text-yellow-300">
                <%= t("curator.audio_tours.pending") %>
              </span>
            <% end %>
          </dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.audio_tours.duration") %></dt>
          <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= @audio_tour.estimated_duration || "-" %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.audio_tours.word_count") %></dt>
          <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= @audio_tour.word_count || "-" %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.audio_tours.created_at") %></dt>
          <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= @audio_tour.created_at.strftime("%d.%m.%Y %H:%M") %></dd>
        </div>

        <% if @audio_tour.audio_ready? %>
          <div class="sm:col-span-2">
            <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 mb-2"><%= t("curator.audio_tours.audio_player") %></dt>
            <dd>
              <audio controls class="w-full">
                <source src="<%= rails_blob_path(@audio_tour.audio_file, only_path: true) %>" type="<%= @audio_tour.audio_file.content_type %>">
                <%= t("curator.audio_tours.audio_not_supported") %>
              </audio>
            </dd>
          </div>
        <% end %>

        <% if @audio_tour.script.present? %>
          <div class="sm:col-span-2">
            <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.audio_tours.script") %></dt>
            <dd class="mt-1 text-sm text-gray-900 dark:text-white whitespace-pre-wrap"><%= @audio_tour.script %></dd>
          </div>
        <% end %>
      </dl>

    </div>
  </div>
</div>
