<%# Locals: moments (the traveller's own, private + public). Read-only display —
    capture happens on the walk; here you can only publish/unpublish. %>
<div class="mt-8 bg-white dark:bg-gray-800 rounded-2xl p-4 sm:p-6 shadow-lg" data-controller="moment-lightbox">
  <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4 flex items-center">
    <span class="w-10 h-10 bg-emerald-100 dark:bg-emerald-900/30 rounded-xl flex items-center justify-center mr-3 flex-shrink-0">
      <svg class="w-5 h-5 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
    </span>
    <%= t("profile.my_moments.title", default: "Moji momenti") %>
  </h2>

  <% if moments.any? %>
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
      <% moments.each do |moment| %>
        <% next unless moment.displayable? %>
        <% location_name = moment.location.name %>
        <%= turbo_frame_tag dom_id(moment), class: "relative block overflow-hidden rounded-xl border border-gray-100 dark:border-gray-700" do %>
          <button type="button" class="block w-full cursor-zoom-in"
                  data-action="moment-lightbox#open"
                  data-moment-lightbox-url="<%= photo_plan_moment_path(moment.plan, moment, size: "square") %>">
            <%= image_tag photo_plan_moment_path(moment.plan, moment, size: "square"),
                  class: "aspect-square w-full object-cover", loading: "lazy", alt: location_name %>
          </button>

          <div class="pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 to-transparent p-2">
            <p class="truncate text-xs font-semibold text-white"><%= location_name %></p>
          </div>

          <% if moment.visibility_public_moment? %>
            <%= button_to unpublish_plan_moment_path(moment.plan, moment), method: :patch,
                  class: "absolute right-1.5 top-1.5 flex size-8 items-center justify-center rounded-full #{moment.approved? ? "bg-emerald-600" : "bg-amber-500"} text-white shadow",
                  title: (moment.approved? ? t("plans.moments.public") : t("plans.moments.pending")),
                  aria: { label: t("plans.moments.make_private") } do %>
              <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0zM3.6 9h16.8M3.6 15h16.8M12 3a15 15 0 010 18M12 3a15 15 0 000 18"/></svg>
            <% end %>
          <% else %>
            <%= button_to publish_plan_moment_path(moment.plan, moment), method: :patch,
                  class: "absolute right-1.5 top-1.5 flex size-8 items-center justify-center rounded-full bg-white/90 text-gray-600 shadow hover:text-emerald-600 dark:bg-gray-900/80 dark:text-gray-300",
                  title: t("plans.moments.share_prompt"),
                  aria: { label: t("plans.moments.share") } do %>
              <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0zM3.6 9h16.8M3.6 15h16.8M12 3a15 15 0 010 18M12 3a15 15 0 000 18"/></svg>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="py-4 text-center text-sm text-gray-500 dark:text-gray-400"><%= t("profile.my_moments.empty", default: "Još nemaš nijedan momenat") %></p>
  <% end %>

  <div data-moment-lightbox-target="overlay"
       data-action="click->moment-lightbox#closeOnBackground"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/80 p-4">
    <button type="button" data-action="moment-lightbox#close"
            class="absolute right-4 top-4 flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/20"
            aria-label="<%= t('common.close') %>">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <img data-moment-lightbox-target="image" src="" alt="" class="max-h-[85vh] max-w-full rounded-lg object-contain shadow-2xl">
  </div>
</div>
