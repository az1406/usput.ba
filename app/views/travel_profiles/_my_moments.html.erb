<%# Your Moments card for the profile page — private to the viewer. %>
<%# Locals: moments (Array of Moment, may be empty). %>
<div class="mt-8 bg-white dark:bg-gray-800 rounded-2xl p-4 sm:p-6 shadow-lg" data-controller="moment-lightbox">
  <div class="flex items-start justify-between gap-3 mb-4">
    <h2 class="text-xl font-bold text-gray-900 dark:text-white flex items-center">
      <span class="w-10 h-10 bg-emerald-100 dark:bg-emerald-900/30 rounded-xl flex items-center justify-center mr-3 flex-shrink-0">
        <svg class="w-5 h-5 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
      </span>
      <%= t("profile.my_moments.title") %>
    </h2>

    <% if moments.any? %>
      <span class="inline-flex items-center rounded-full bg-emerald-100 dark:bg-emerald-900/30 px-2.5 py-0.5 text-xs font-medium text-emerald-800 dark:text-emerald-300 flex-shrink-0 mt-1">
        <%= t("plans.moments.count", count: moments.size) %>
      </span>
    <% end %>
  </div>

  <% if moments.any? %>
    <% moments.group_by(&:plan).each do |plan, all_plan_moments| %>
      <% plan_moments = all_plan_moments.select(&:displayable?) %>
      <% next if plan_moments.empty? %>
      <div class="mb-5 last:mb-0">
        <div class="flex items-center justify-between gap-2 mb-2">
          <%= link_to start_plan_path(plan), class: "text-sm font-semibold text-gray-900 dark:text-white hover:text-emerald-600 dark:hover:text-emerald-400 truncate" do %>
            <%= plan.display_title %>
          <% end %>
          <span class="text-xs text-gray-400 dark:text-gray-500 flex-shrink-0">
            <%= t("plans.moments.count", count: plan_moments.size) %>
          </span>
        </div>

        <div class="flex flex-wrap gap-2">
          <% plan_moments.first(8).each do |moment| %>
            <button type="button" class="relative group block cursor-zoom-in"
                    data-action="moment-lightbox#open"
                    data-moment-lightbox-url="<%= photo_plan_moment_path(plan, moment, size: "square") %>">
              <%= image_tag photo_plan_moment_path(plan, moment, size: "thumb"),
                    class: "w-20 h-20 object-cover rounded-lg border border-gray-200 dark:border-gray-700",
                    alt: moment.note.presence || moment.location.name,
                    title: [ moment.location.name, moment.note.presence ].compact.join(" — ") %>
              <span class="absolute inset-x-0 bottom-0 rounded-b-lg bg-black/55 px-1 py-0.5 text-[10px] leading-tight text-white truncate">
                <%= moment.location.name %>
              </span>
            </button>
          <% end %>

          <% if plan_moments.size > 8 %>
            <%= link_to start_plan_path(plan), class: "w-20 h-20 rounded-lg border border-dashed border-gray-300 dark:border-gray-600 flex items-center justify-center text-xs font-medium text-gray-500 dark:text-gray-400 hover:border-emerald-400" do %>
              +<%= plan_moments.size - 8 %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-8">
      <svg class="w-10 h-10 mx-auto text-gray-300 dark:text-gray-600 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
      </svg>
      <p class="text-sm text-gray-500 dark:text-gray-400"><%= t("profile.my_moments.empty") %></p>
      <p class="mt-1 text-xs text-gray-400 dark:text-gray-500"><%= t("profile.my_moments.empty_hint") %></p>
    </div>
  <% end %>

  <div data-moment-lightbox-target="overlay"
       data-action="click->moment-lightbox#closeOnBackground"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/80 p-4">
    <button type="button" data-action="moment-lightbox#close"
            class="absolute top-4 right-4 flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/20"
            aria-label="<%= t('common.close', default: 'Zatvori') %>">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
    <img data-moment-lightbox-target="image" src="" alt="" class="max-h-[85vh] max-w-full rounded-lg object-contain shadow-2xl">
  </div>
</div>
