<%# Everything showing one location's moments. The walk has the step; the plan
    panel has the location block, the summary and the flash. Turbo skips the
    targets the requesting page does not have. %>
<% explore = params[:context] == "explore"
   moments = current_user.moments.where(location_id: location.id).with_attached_photo.includes(:plan).chronological
   visited = if explore
     current_user.plan_visits.exists?(location_id: location.id)
   else
     current_user.plan_visits.exists?(plan_id: @plan.id, location_id: location.id)
   end %>

<%= turbo_stream.replace dom_id(location, :step) do %>
  <%= render "plans/plan_step",
        plan: @plan,
        location: location,
        moments: moments,
        visited: visited,
        show_photo: false,
        show_name: false,
        overlay: true,
        context: params[:context],
        alert: local_assigns[:alert] %>
<% end %>

<%= turbo_stream.replace dom_id(location, :stories), method: :morph do %>
  <div id="<%= dom_id(location, :stories) %>" class="relative h-full w-full">
    <%= render "plans/story_slides",
          plan: @plan,
          location: location,
          moments: moments,
          public_moments: Moment.publicly_visible.where(location_id: location.id).with_attached_photo.chronological,
          context: params[:context] %>
  </div>
<% end %>

<% if local_assigns[:alert].present? %>
  <%= turbo_stream.replace "moment-flash" do %>
    <div id="moment-flash" class="mb-4 rounded-lg bg-red-50 dark:bg-red-900/30 px-4 py-3 text-sm text-red-800 dark:text-red-300">
      <%= alert %>
    </div>
  <% end %>
<% else %>
  <%= turbo_stream.replace "moment-flash" do %>
    <div id="moment-flash"></div>
  <% end %>
<% end %>
